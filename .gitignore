# ============================================================
# Pacha-Chain-Origin .gitignore
# ============================================================

# --- Foundry ---
/cache/
/out/
/broadcast/

# --- Dependencies ---
# /lib/ is tracked via git submodules (foundry convention)

# --- Node (si se usa para scripts auxiliares) ---
/node_modules/
/package-lock.json

# --- Environment ---
.env
.env.local
.env.*.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Coverage ---
/coverage/
lcov.info

# --- Generated output ---
/output/

# --- Frontend (Next.js) ---
frontend/.next/
frontend/node_modules/
frontend/.env.local

# --- Misc ---
*.log
