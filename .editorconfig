# ============================================================
# Pacha-Chain-Origin EditorConfig
# https://editorconfig.org
# ============================================================

root = true

# --- Defaults ---
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# --- Solidity ---
[*.sol]
indent_size = 4

# --- Markdown ---
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# --- JSON ---
[*.json]
indent_size = 2
insert_final_newline = false

# --- YAML / GitHub Actions ---
[*.{yml,yaml}]
indent_size = 2

# --- Shell / PowerShell scripts ---
[*.{sh,ps1}]
indent_size = 2

# --- TOML (foundry.toml) ---
[*.toml]
indent_size = 2

# --- Makefiles ---
[Makefile]
indent_style = tab
