# ============================================================
# Pacha-Chain-Origin Environment Variables
# ============================================================
# Copia este archivo como .env y llena los valores
# NUNCA commits el archivo .env real al repositorio
# ============================================================

# ---- Wallet ----
# Private key de la wallet para deployment (SIN el prefijo 0x)
# Usa una wallet de TESTNET dedicada, NUNCA la de producción
PRIVATE_KEY=

# ---- RPC Endpoints ----
# Polygon Amoy Testnet
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ---- Block Explorer ----
# API key de PolygonScan para verificación de contratos
# Obtenla en: https://amoy.polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ---- IPFS (Fase 2) ----
# Pinata JWT para upload de metadata y archivos a IPFS
# Obtenlo en: https://app.pinata.cloud → API Keys → New Key → JWT
PINATA_JWT=

# Pinata API keys (alternativa al JWT, para compatibilidad)
# Obtenlas en: https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ---- Frontend (Fase 4) ----
# URL base de la web de verificación pública
VERIFY_BASE_URL=https://pacha-chain.xyz/verify

# ---- Direcciones Desplegadas (se llenan después del deploy) ----
PACHA_CHAIN_ORIGIN_ADDRESS=
