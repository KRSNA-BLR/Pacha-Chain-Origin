{
  "$schema": "https://json.schemastore.org/jscpd.json",
  "threshold": 5,
  "minLines": 10,
  "minTokens": 50,
  "reporters": ["json", "console"],
  "ignore": [
    "node_modules/**",
    "frontend/node_modules/**",
    "frontend/.next/**",
    "lib/**",
    "broadcast/**",
    "cache/**",
    "output/**",
    "**/*.json",
    "**/*.css",
    "**/*.md"
  ],
  "format": [
    "typescript",
    "tsx",
    "javascript",
    "solidity"
  ],
  "absolute": false,
  "gitignore": true
}
